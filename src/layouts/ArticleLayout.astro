---
const { frontmatter } = Astro.props;
const { title, description, publishedAt, eyecatch, keyword } = frontmatter;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | Shift Breeze</title>
  <meta name="description" content={description} />
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  {eyecatch && <meta property="og:image" content={eyecatch} />}
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --color-bg: #0f1117;
      --color-bg-card: #1a1d27;
      --color-bg-card-hover: #22263a;
      --color-border: #2a2d3e;
      --color-accent: #6c63ff;
      --color-accent-light: #8b85ff;
      --color-accent-glow: rgba(108, 99, 255, 0.15);
      --color-text: #e8eaf0;
      --color-text-muted: #8b8fa8;
      --color-heading: #ffffff;
      --color-success: #4ade80;
      --color-warning: #fbbf24;
      --font-body: 'Noto Sans JP', sans-serif;
      --font-display: 'Outfit', sans-serif;
      --max-width: 780px;
      --radius: 12px;
    }

    body {
      background: var(--color-bg);
      color: var(--color-text);
      font-family: var(--font-body);
      font-size: 17px;
      line-height: 1.85;
      -webkit-font-smoothing: antialiased;
    }

    .site-header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(15, 17, 23, 0.85);
      backdrop-filter: blur(12px);
      border-bottom: 1px solid var(--color-border);
      padding: 0 24px;
    }
    .site-header__inner {
      max-width: 1100px;
      margin: 0 auto;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .site-logo {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      color: var(--color-heading);
      text-decoration: none;
      letter-spacing: -0.02em;
    }
    .site-logo span { color: var(--color-accent); }

    .article-hero {
      padding: 64px 24px 48px;
      max-width: var(--max-width);
      margin: 0 auto;
    }
    .article-meta {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 24px;
    }
    .article-keyword {
      display: inline-block;
      padding: 4px 12px;
      background: var(--color-accent-glow);
      border: 1px solid var(--color-accent);
      border-radius: 100px;
      font-size: 13px;
      color: var(--color-accent-light);
      font-weight: 500;
    }
    .article-date {
      font-size: 13px;
      color: var(--color-text-muted);
    }
    .article-title {
      font-family: var(--font-display);
      font-size: clamp(28px, 5vw, 42px);
      font-weight: 700;
      color: var(--color-heading);
      line-height: 1.3;
      letter-spacing: -0.02em;
      margin-bottom: 20px;
    }
    .article-description {
      font-size: 18px;
      color: var(--color-text-muted);
      line-height: 1.7;
      border-left: 3px solid var(--color-accent);
      padding-left: 16px;
    }

    .article-eyecatch {
      max-width: var(--max-width);
      margin: 0 auto 48px;
      padding: 0 24px;
    }
    .article-eyecatch img {
      width: 100%;
      border-radius: var(--radius);
      border: 1px solid var(--color-border);
    }

    .article-body {
      max-width: var(--max-width);
      margin: 0 auto;
      padding: 0 24px 96px;
    }

    .article-body h2 {
      font-family: var(--font-display);
      font-size: clamp(22px, 3vw, 28px);
      font-weight: 700;
      color: var(--color-heading);
      margin: 64px 0 24px;
      padding: 20px 24px;
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-left: 4px solid var(--color-accent);
      border-radius: 0 var(--radius) var(--radius) 0;
      letter-spacing: -0.01em;
    }
    .article-body h3 {
      font-size: 20px;
      font-weight: 700;
      color: var(--color-heading);
      margin: 40px 0 16px;
      padding-bottom: 8px;
      border-bottom: 1px solid var(--color-border);
    }
    .article-body h4 {
      font-size: 17px;
      font-weight: 700;
      color: var(--color-accent-light);
      margin: 28px 0 12px;
    }

    .article-body p {
      margin-bottom: 20px;
      color: var(--color-text);
    }

    .article-body ul, .article-body ol {
      margin: 0 0 24px 0;
      padding-left: 0;
      list-style: none;
    }
    .article-body ul li {
      position: relative;
      padding: 8px 16px 8px 32px;
      margin-bottom: 4px;
      background: var(--color-bg-card);
      border-radius: 8px;
      border: 1px solid var(--color-border);
    }
    .article-body ul li::before {
      content: '';
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      width: 8px;
      height: 8px;
      background: var(--color-accent);
      border-radius: 50%;
    }
    .article-body ol {
      counter-reset: item;
    }
    .article-body ol li {
      position: relative;
      padding: 10px 16px 10px 48px;
      margin-bottom: 8px;
      background: var(--color-bg-card);
      border-radius: 8px;
      border: 1px solid var(--color-border);
      counter-increment: item;
    }
    .article-body ol li::before {
      content: counter(item);
      position: absolute;
      left: 12px;
      top: 50%;
      transform: translateY(-50%);
      width: 24px;
      height: 24px;
      background: var(--color-accent);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      font-size: 12px;
      font-weight: 700;
      color: white;
      line-height: 24px;
      text-align: center;
    }

    .article-body table {
      width: 100%;
      border-collapse: collapse;
      margin: 32px 0;
      border-radius: var(--radius);
      overflow: hidden;
      border: 1px solid var(--color-border);
      font-size: 15px;
    }
    .article-body thead {
      background: var(--color-accent);
    }
    .article-body thead th {
      padding: 14px 16px;
      color: white;
      font-weight: 700;
      text-align: left;
      font-family: var(--font-display);
      font-size: 14px;
    }
    .article-body tbody tr {
      border-bottom: 1px solid var(--color-border);
      transition: background 0.15s;
    }
    .article-body tbody tr:hover {
      background: var(--color-bg-card-hover);
    }
    .article-body tbody td {
      padding: 12px 16px;
      color: var(--color-text);
    }
    .article-body tbody tr:last-child {
      border-bottom: none;
    }

    .article-body .point-box {
      background: var(--color-accent-glow);
      border: 1px solid var(--color-accent);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin: 32px 0;
    }
    .article-body .point-box-title {
      font-weight: 700;
      color: var(--color-accent-light);
      margin-bottom: 8px;
      font-size: 15px;
    }

    .article-body .warning-box {
      background: rgba(251, 191, 36, 0.08);
      border: 1px solid var(--color-warning);
      border-radius: var(--radius);
      padding: 20px 24px;
      margin: 32px 0;
    }

    .article-body img {
      width: 100%;
      border-radius: var(--radius);
      border: 1px solid var(--color-border);
      margin: 32px 0;
    }

    .article-body code {
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      padding: 2px 6px;
      border-radius: 4px;
      font-size: 14px;
      color: var(--color-accent-light);
    }
    .article-body pre {
      background: var(--color-bg-card);
      border: 1px solid var(--color-border);
      border-radius: var(--radius);
      padding: 20px;
      overflow-x: auto;
      margin: 24px 0;
    }
    .article-body pre code {
      background: none;
      border: none;
      padding: 0;
      color: var(--color-text);
    }

    .article-body strong {
      color: var(--color-heading);
      font-weight: 700;
    }

    .article-body a {
      color: var(--color-accent-light);
      text-decoration: none;
      border-bottom: 1px solid rgba(108, 99, 255, 0.4);
      transition: border-color 0.15s;
    }
    .article-body a:hover {
      border-color: var(--color-accent-light);
    }

    .site-footer {
      border-top: 1px solid var(--color-border);
      padding: 32px 24px;
      text-align: center;
      color: var(--color-text-muted);
      font-size: 14px;
    }

    @media (max-width: 640px) {
      .article-hero { padding: 40px 16px 32px; }
      .article-body { padding: 0 16px 64px; }
      .article-eyecatch { padding: 0 16px; }
      .article-body h2 { font-size: 20px; padding: 14px 16px; }
    }
  </style>
</head>
<body>

  <header class="site-header">
    <div class="site-header__inner">
      <a href="/" class="site-logo">Shift<span>Breeze</span></a>
    </div>
  </header>

  <main>
    <div class="article-hero">
      <div class="article-meta">
        <span class="article-keyword">{keyword}</span>
        <span class="article-date">{publishedAt}</span>
      </div>
      <h1 class="article-title">{title}</h1>
      <p class="article-description">{description}</p>
    </div>

    {eyecatch && (
      <div class="article-eyecatch">
        <img src={eyecatch} alt={title} loading="eager" />
      </div>
    )}

    <article class="article-body">
      <slot />
    </article>
  </main>

  <footer class="site-footer">
    <p>© 2026 ShiftBreeze. All rights reserved.</p>
  </footer>

</body>
</html>
