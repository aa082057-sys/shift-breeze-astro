---
// src/pages/index.astro
// Phase 11: カテゴリ別セクション / 2列グリッド(PC) / リスト(SP) / サイドバー
// index.json の popularity_source / killer_by_category / categories を利用
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shift Breeze | AI・副業・キャリアの実践メディア</title>
  <meta name="description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。検索上位の情報より、一歩先の実践知識を。" />
  <meta property="og:title" content="Shift Breeze | AI・副業・キャリアの実践メディア" />
  <meta property="og:description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0c12;
      --bg-card: #13161f;
      --bg-card-hover: #1a1d2a;
      --border: #1e2133;
      --accent: #6c63ff;
      --accent-2: #ff6584;
      --accent-glow: rgba(108, 99, 255, 0.12);
      --text: #dde1f0;
      --text-muted: #7b80a0;
      --heading: #ffffff;
      --font-body: 'Noto Sans JP', sans-serif;
      --font-display: 'Outfit', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.75;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ヘッダー */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 12, 18, 0.88);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .header__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 800;
      color: var(--heading);
      text-decoration: none;
      letter-spacing: -0.03em;
    }
    .logo span { color: var(--accent); }

    /* ヒーロー（コンパクト化） */
    .hero {
      padding: 56px 24px 40px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 720px;
      height: 720px;
      background: radial-gradient(circle, rgba(108,99,255,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero__tag {
      display: inline-block;
      padding: 5px 14px;
      background: var(--accent-glow);
      border: 1px solid rgba(108,99,255,0.4);
      border-radius: 100px;
      font-size: 12px;
      color: #9d97ff;
      font-weight: 500;
      margin-bottom: 18px;
      letter-spacing: 0.05em;
    }
    .hero__title {
      font-family: var(--font-display);
      font-size: clamp(28px, 5vw, 44px);
      font-weight: 800;
      color: var(--heading);
      line-height: 1.2;
      letter-spacing: -0.03em;
      margin-bottom: 14px;
    }
    .hero__title em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero__desc {
      font-size: 15px;
      color: var(--text-muted);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* レイアウト: メイン + サイドバー */
    .layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 72px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 40px;
    }
    @media (min-width: 1024px) {
      .layout {
        grid-template-columns: minmax(0, 1fr) 280px;
        gap: 48px;
      }
    }

    /* セクション */
    .section { margin-bottom: 56px; }
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      color: var(--heading);
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .section-title small {
      font-size: 12px;
      color: var(--text-muted);
      font-weight: 500;
    }
    .section-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .section-more {
      font-size: 12px;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
    }
    .section-more:hover { text-decoration: underline; }

    /* キラーカード（セクション先頭、幅広） */
    .killer-card {
      display: grid;
      grid-template-columns: 1fr;
      gap: 0;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 14px;
      overflow: hidden;
      text-decoration: none;
      margin-bottom: 16px;
      transition: border-color 0.2s, box-shadow 0.2s;
    }
    .killer-card:hover {
      border-color: var(--accent);
      box-shadow: 0 12px 32px rgba(108,99,255,0.1);
    }
    .killer-card__img {
      aspect-ratio: 16/9;
      width: 100%;
      object-fit: cover;
      background: linear-gradient(135deg, #13161f 0%, #1e2133 100%);
    }
    .killer-card__body { padding: 20px 22px; }
    .killer-card__flag {
      display: inline-block;
      padding: 3px 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #fff;
      border-radius: 100px;
      font-size: 11px;
      font-weight: 700;
      letter-spacing: 0.05em;
      margin-bottom: 10px;
    }
    .killer-card__title {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--heading);
      line-height: 1.45;
      margin-bottom: 8px;
    }
    .killer-card__desc {
      font-size: 13px;
      color: var(--text-muted);
      line-height: 1.65;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    @media (min-width: 720px) {
      .killer-card { grid-template-columns: 44% 1fr; }
      .killer-card__img { height: 100%; aspect-ratio: auto; }
      .killer-card__body { padding: 24px 28px; }
      .killer-card__title { font-size: 22px; }
      .killer-card__desc { -webkit-line-clamp: 3; font-size: 14px; }
    }

    /* 通常カードグリッド: PC=2列, SP=リスト（横長サムネ+タイトル） */
    .cards {
      display: grid;
      grid-template-columns: 1fr;
      gap: 10px;
    }
    @media (min-width: 720px) {
      .cards { grid-template-columns: repeat(2, minmax(0, 1fr)); gap: 16px; }
    }

    /* SP: 横長リスト型 */
    .card {
      display: grid;
      grid-template-columns: 120px 1fr;
      gap: 12px;
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 10px;
      text-decoration: none;
      transition: border-color 0.15s, background 0.15s;
    }
    .card:hover { border-color: var(--accent); background: var(--bg-card-hover); }
    .card__img {
      width: 120px;
      height: 80px;
      object-fit: cover;
      border-radius: 6px;
      background: linear-gradient(135deg, #13161f 0%, #1e2133 100%);
    }
    .card__body { min-width: 0; display: flex; flex-direction: column; justify-content: space-between; }
    .card__title {
      font-size: 14px;
      font-weight: 600;
      color: var(--heading);
      line-height: 1.45;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card__date {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: 6px;
    }

    /* PC: カード型へ切替 */
    @media (min-width: 720px) {
      .card {
        grid-template-columns: 1fr;
        gap: 0;
        padding: 0;
        overflow: hidden;
      }
      .card__img {
        width: 100%;
        height: auto;
        aspect-ratio: 16/9;
        border-radius: 0;
      }
      .card__body { padding: 14px 16px; gap: 6px; }
      .card__title { font-size: 15px; -webkit-line-clamp: 2; }
    }

    /* サイドバー */
    .sidebar { display: flex; flex-direction: column; gap: 28px; }
    @media (max-width: 1023px) {
      .sidebar { order: 2; }
    }
    .widget {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 12px;
      padding: 18px 18px 14px;
    }
    .widget__title {
      font-family: var(--font-display);
      font-size: 13px;
      font-weight: 700;
      letter-spacing: 0.05em;
      color: var(--heading);
      margin-bottom: 14px;
      text-transform: uppercase;
    }
    .widget__list { list-style: none; display: flex; flex-direction: column; gap: 8px; }
    .widget__list a {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      padding: 6px 10px;
      border-radius: 6px;
      color: var(--text);
      text-decoration: none;
      font-size: 13px;
      line-height: 1.5;
      transition: background 0.12s;
    }
    .widget__list a:hover { background: var(--bg-card-hover); color: var(--accent); }
    .widget__list .count { color: var(--text-muted); font-size: 11px; flex-shrink: 0; }

    .popular-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      padding: 6px 0;
      text-decoration: none;
    }
    .popular-item__rank {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.2;
    }
    .popular-item__title {
      font-size: 12px;
      color: var(--text);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .popular-item:hover .popular-item__title { color: var(--accent); }

    /* フッター */
    .footer {
      border-top: 1px solid var(--border);
      padding: 28px 24px;
      text-align: center;
      color: var(--text-muted);
      font-size: 13px;
    }
    .footer a { color: var(--text-muted); text-decoration: none; }
    .footer a:hover { color: var(--accent); }

    .empty, .loading {
      text-align: center;
      padding: 48px 0;
      color: var(--text-muted);
      font-size: 14px;
    }

    @media (max-width: 720px) {
      .hero { padding: 40px 16px 28px; }
      .layout { padding: 0 16px 48px; gap: 32px; }
      .section { margin-bottom: 40px; }
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header__inner">
      <a href="/" class="logo">Shift<span>Breeze</span></a>
    </div>
  </header>

  <main>
    <div class="hero">
      <div class="hero__tag">AI × 副業 × キャリア</div>
      <h1 class="hero__title">
        検索上位より<br>
        <em>一歩先の実践知識</em>を
      </h1>
      <p class="hero__desc">
        AI活用・副業・キャリアチェンジに関する、実際に使える情報をお届けします
      </p>
    </div>

    <div class="layout">
      <div id="main-col">
        <div class="loading">記事を読み込んでいます...</div>
      </div>

      <aside class="sidebar" id="sidebar"></aside>
    </div>
  </main>

  <footer class="footer">
    <p>© 2026 <a href="/">ShiftBreeze</a>. All rights reserved.</p>
  </footer>

  <script>
    function escapeHtml(s) {
      return String(s || '').replace(/[&<>"']/g, c => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
      }[c]));
    }

    function renderCard(a) {
      const img = a.eyecatch
        ? `<img class="card__img" src="${escapeHtml(a.eyecatch)}" alt="" loading="lazy" onerror="this.style.display='none'">`
        : `<div class="card__img"></div>`;
      return `<a href="${escapeHtml(a.url)}" class="card">
        ${img}
        <div class="card__body">
          <div class="card__title">${escapeHtml(a.title)}</div>
          <div class="card__date">${escapeHtml(a.published_at || '')}</div>
        </div>
      </a>`;
    }

    function renderKiller(a, label) {
      const img = a.eyecatch
        ? `<img class="killer-card__img" src="${escapeHtml(a.eyecatch)}" alt="" loading="lazy">`
        : `<div class="killer-card__img"></div>`;
      return `<a href="${escapeHtml(a.url)}" class="killer-card">
        ${img}
        <div class="killer-card__body">
          <span class="killer-card__flag">${escapeHtml(label)} ピック</span>
          <div class="killer-card__title">${escapeHtml(a.title)}</div>
          <div class="killer-card__desc">${escapeHtml(a.description || '')}</div>
        </div>
      </a>`;
    }

    function renderSection(cat, killer, rest) {
      const more = rest.length > 5 ? `<a class="section-more" href="/category/${cat.slug}/">もっと見る →</a>` : '';
      const killerHtml = killer ? renderKiller(killer, cat.label) : '';
      const cardsHtml = rest.slice(0, 6).map(renderCard).join('');
      const empty = !killer && rest.length === 0
        ? '<div class="empty">このカテゴリの記事はまだありません。</div>'
        : '';
      return `<section class="section">
        <div class="section-header">
          <h2 class="section-title">${escapeHtml(cat.label)} <small>${killer || rest.length ? (1 + rest.length) + '記事' : ''}</small></h2>
          <div class="section-line"></div>
          ${more}
        </div>
        ${killerHtml}
        <div class="cards">${cardsHtml}</div>
        ${empty}
      </section>`;
    }

    function renderSidebar(categories, counts, popular) {
      const catList = categories
        .filter(c => (counts[c.slug] || 0) > 0)
        .map(c => `<li><a href="/category/${c.slug}/">${escapeHtml(c.label)} <span class="count">${counts[c.slug]}</span></a></li>`)
        .join('');
      const popHtml = popular.map((a, i) => `
        <a href="${escapeHtml(a.url)}" class="popular-item">
          <div class="popular-item__rank">${i + 1}</div>
          <div class="popular-item__title">${escapeHtml(a.title)}</div>
        </a>
      `).join('');

      return `
        <div class="widget">
          <h3 class="widget__title">カテゴリ</h3>
          <ul class="widget__list">${catList || '<li style="color:#7b80a0;font-size:12px;">まだ記事がありません</li>'}</ul>
        </div>
        <div class="widget">
          <h3 class="widget__title">人気記事</h3>
          <div>${popHtml || '<div style="color:#7b80a0;font-size:12px;">集計中</div>'}</div>
        </div>
      `;
    }

    async function load() {
      const mainCol = document.getElementById('main-col');
      const sidebar = document.getElementById('sidebar');
      try {
        const res = await fetch('/articles/index.json');
        if (!res.ok) throw new Error('index.json missing');
        const data = await res.json();

        const articles = data.articles || [];
        const categories = data.categories || [];
        const killerByCat = data.killer_by_category || {};
        const popular = data.popular_top5 || [];

        if (articles.length === 0) {
          mainCol.innerHTML = '<div class="empty">記事はまだありません</div>';
          sidebar.innerHTML = '';
          return;
        }

        const counts = {};
        for (const a of articles) counts[a.category || 'general'] = (counts[a.category || 'general'] || 0) + 1;

        const sections = categories.map(cat => {
          const killer = killerByCat[cat.slug];
          const killerId = killer ? killer.task_id : null;
          const inCat = articles.filter(a => a.category === cat.slug && a.task_id !== killerId);
          return (killer || inCat.length) ? renderSection(cat, killer, inCat) : '';
        }).filter(Boolean).join('');

        mainCol.innerHTML = sections || '<div class="empty">記事がまだありません</div>';
        sidebar.innerHTML = renderSidebar(categories, counts, popular);
      } catch (e) {
        console.error(e);
        mainCol.innerHTML = '<div class="empty">記事の読み込みに失敗しました</div>';
        sidebar.innerHTML = '';
      }
    }
    load();
  </script>

</body>
</html>
