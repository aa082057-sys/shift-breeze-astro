---
// src/pages/index.astro
// Phase 11-A2: 70/30 layout, 200px card image, 2-col grid (PC), 80px list (SP)
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shift Breeze | AI・副業・キャリアの実践メディア</title>
  <meta name="description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。検索上位の情報より、一歩先の実践知識を。" />
  <meta property="og:title" content="Shift Breeze | AI・副業・キャリアの実践メディア" />
  <meta property="og:description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0c12;
      --bg-card: #13161f;
      --bg-card-hover: #1a1d2a;
      --border: #1e2133;
      --accent: #6c63ff;
      --accent-2: #ff6584;
      --accent-glow: rgba(108, 99, 255, 0.12);
      --text: #dde1f0;
      --text-muted: #7b80a0;
      --heading: #ffffff;
      --font-body: 'Noto Sans JP', sans-serif;
      --font-display: 'Outfit', sans-serif;
      --bp-tablet: 720px;
      --bp-desktop: 1024px;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.7;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ===== Header ===== */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 12, 18, 0.88);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .header__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px;
      height: 60px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 800;
      color: var(--heading);
      text-decoration: none;
      letter-spacing: -0.03em;
    }
    .logo span { color: var(--accent); }

    /* ===== Hero (compact) ===== */
    .hero {
      padding: 48px 20px 32px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 720px;
      height: 720px;
      background: radial-gradient(circle, rgba(108,99,255,0.08) 0%, transparent 70%);
      pointer-events: none;
      z-index: 0;
    }
    .hero > * { position: relative; z-index: 1; }
    .hero__tag {
      display: inline-block;
      padding: 4px 12px;
      background: var(--accent-glow);
      border: 1px solid rgba(108,99,255,0.4);
      border-radius: 100px;
      font-size: 12px;
      color: #9d97ff;
      font-weight: 500;
      margin-bottom: 16px;
    }
    .hero__title {
      font-family: var(--font-display);
      font-size: clamp(26px, 4.5vw, 40px);
      font-weight: 800;
      color: var(--heading);
      line-height: 1.2;
      letter-spacing: -0.03em;
      margin-bottom: 12px;
    }
    .hero__title em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero__desc {
      font-size: 14px;
      color: var(--text-muted);
      max-width: 480px;
      margin: 0 auto;
      line-height: 1.65;
    }

    /* ===== Layout: main 70% / sidebar 30% on desktop ===== */
    .layout {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 20px 60px;
      display: grid;
      grid-template-columns: 1fr;
      gap: 32px;
    }
    @media (min-width: 1024px) {
      .layout {
        grid-template-columns: minmax(0, 7fr) minmax(0, 3fr);
        gap: 40px;
        align-items: start;
      }
    }

    /* ===== Section ===== */
    .section { margin-bottom: 48px; }
    .section:last-child { margin-bottom: 0; }
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 20px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 700;
      color: var(--heading);
      display: flex;
      align-items: baseline;
      gap: 10px;
    }
    .section-title small {
      font-size: 11px;
      color: var(--text-muted);
      font-weight: 500;
    }
    .section-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .section-more {
      font-size: 12px;
      color: var(--accent);
      text-decoration: none;
      white-space: nowrap;
    }
    .section-more:hover { text-decoration: underline; }

    /* ===== Card grid ===== */
    .cards {
      display: grid;
      grid-template-columns: 1fr;         /* SP: 1 col list */
      gap: 12px;
    }
    @media (min-width: 720px) {
      .cards {
        grid-template-columns: repeat(2, minmax(0, 1fr));  /* PC/tablet: 2 col */
        gap: 20px;
      }
    }

    /* ===== Card (PC default: vertical image+body) ===== */
    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      overflow: hidden;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: transform 0.15s, border-color 0.15s, box-shadow 0.15s;
    }
    .card:hover {
      transform: translateY(-3px);
      border-color: var(--accent);
      box-shadow: 0 10px 28px rgba(108,99,255,0.12);
    }
    .card__img {
      width: 100%;
      height: 200px;
      object-fit: cover;
      aspect-ratio: 16 / 9;
      background: linear-gradient(135deg, #13161f 0%, #1e2133 100%);
      display: block;
    }
    .card__body {
      padding: 14px 16px 16px;
      display: flex;
      flex-direction: column;
      gap: 6px;
      flex: 1;
    }
    .card__title {
      font-size: 15px;
      font-weight: 700;
      color: var(--heading);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 2;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card__excerpt {
      font-size: 12px;
      color: var(--text-muted);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 1;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .card__date {
      font-size: 11px;
      color: var(--text-muted);
      margin-top: auto;
      padding-top: 4px;
    }

    /* ===== SP list style (<720) ===== */
    @media (max-width: 719px) {
      .card {
        flex-direction: row;
        align-items: stretch;
        padding: 10px;
        gap: 12px;
        border-radius: 8px;
      }
      .card__img {
        width: 80px;
        height: 80px;
        flex: 0 0 80px;
        aspect-ratio: 1 / 1;
        border-radius: 6px;
      }
      .card__body {
        padding: 0;
        gap: 4px;
        min-width: 0;
      }
      .card__title {
        font-size: 14px;
        -webkit-line-clamp: 3;
      }
      .card__excerpt { display: none; }  /* SP: excerpt hidden for list clarity */
      .card__date { font-size: 10px; }
    }

    /* ===== Killer card (spans both columns, highlighted) ===== */
    .card--killer {
      grid-column: 1 / -1;
      border-color: rgba(108, 99, 255, 0.4);
      position: relative;
    }
    @media (min-width: 720px) {
      .card--killer {
        flex-direction: row;   /* image left, body right */
      }
      .card--killer .card__img {
        width: 44%;
        height: auto;
        max-height: 260px;
        flex: 0 0 44%;
        aspect-ratio: 16 / 9;
        border-radius: 0;
      }
      .card--killer .card__body {
        padding: 20px 24px;
        gap: 8px;
      }
      .card--killer .card__title {
        font-size: 18px;
        -webkit-line-clamp: 2;
      }
      .card--killer .card__excerpt {
        -webkit-line-clamp: 3;
        font-size: 13px;
      }
    }
    .card__flag {
      position: absolute;
      top: 10px;
      left: 10px;
      z-index: 2;
      padding: 3px 10px;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      color: #fff;
      border-radius: 100px;
      font-size: 10px;
      font-weight: 700;
      letter-spacing: 0.08em;
      text-transform: uppercase;
    }

    /* ===== Sidebar ===== */
    .sidebar {
      display: flex;
      flex-direction: column;
      gap: 24px;
      min-width: 0;
    }
    @media (min-width: 1024px) {
      .sidebar { position: sticky; top: 80px; }
    }
    .widget {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 10px;
      padding: 16px 16px 14px;
    }
    .widget__title {
      font-family: var(--font-display);
      font-size: 12px;
      font-weight: 700;
      letter-spacing: 0.08em;
      color: var(--heading);
      margin-bottom: 12px;
      text-transform: uppercase;
    }
    .widget__list { list-style: none; display: flex; flex-direction: column; gap: 4px; }
    .widget__list a {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 8px;
      padding: 7px 10px;
      border-radius: 6px;
      color: var(--text);
      text-decoration: none;
      font-size: 13px;
      line-height: 1.4;
      transition: background 0.12s;
    }
    .widget__list a:hover { background: var(--bg-card-hover); color: var(--accent); }
    .widget__list .count {
      color: var(--text-muted);
      font-size: 11px;
      flex-shrink: 0;
    }

    .popular-list {
      display: flex;
      flex-direction: column;
      gap: 10px;
    }
    .popular-item {
      display: grid;
      grid-template-columns: 28px 1fr;
      gap: 10px;
      padding: 4px 0;
      text-decoration: none;
      align-items: flex-start;
    }
    .popular-item__rank {
      font-family: var(--font-display);
      font-size: 18px;
      font-weight: 800;
      color: var(--accent);
      line-height: 1.1;
    }
    .popular-item__title {
      font-size: 12px;
      color: var(--text);
      line-height: 1.5;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .popular-item:hover .popular-item__title { color: var(--accent); }

    /* ===== Footer ===== */
    .footer {
      border-top: 1px solid var(--border);
      padding: 28px 20px;
      text-align: center;
      color: var(--text-muted);
      font-size: 13px;
    }
    .footer a { color: var(--text-muted); text-decoration: none; }
    .footer a:hover { color: var(--accent); }

    .empty, .loading {
      text-align: center;
      padding: 40px 0;
      color: var(--text-muted);
      font-size: 13px;
    }

    @media (max-width: 719px) {
      .hero { padding: 36px 16px 24px; }
      .layout { padding: 0 16px 40px; gap: 24px; }
      .section { margin-bottom: 36px; }
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header__inner">
      <a href="/" class="logo">Shift<span>Breeze</span></a>
    </div>
  </header>

  <main>
    <div class="hero">
      <div class="hero__tag">AI × 副業 × キャリア</div>
      <h1 class="hero__title">
        検索上位より<br>
        <em>一歩先の実践知識</em>を
      </h1>
      <p class="hero__desc">
        AI活用・副業・キャリアチェンジに関する、実際に使える情報をお届けします
      </p>
    </div>

    <div class="layout">
      <div id="main-col">
        <div class="loading">記事を読み込んでいます...</div>
      </div>

      <aside class="sidebar" id="sidebar"></aside>
    </div>
  </main>

  <footer class="footer">
    <p>© 2026 <a href="/">ShiftBreeze</a>. All rights reserved.</p>
  </footer>

  <script>
    function esc(s) {
      return String(s || '').replace(/[&<>"']/g, c => ({
        '&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'
      }[c]));
    }

    function renderCard(a, isKiller, killerLabel) {
      const img = a.eyecatch
        ? `<img class="card__img" src="${esc(a.eyecatch)}" alt="" loading="lazy" onerror="this.style.display='none'">`
        : `<div class="card__img"></div>`;
      const flag = isKiller
        ? `<span class="card__flag">${esc(killerLabel)} ピック</span>`
        : '';
      return `<a href="${esc(a.url)}" class="card${isKiller ? ' card--killer' : ''}">
        ${flag}
        ${img}
        <div class="card__body">
          <div class="card__title">${esc(a.title)}</div>
          <div class="card__excerpt">${esc(a.description || '')}</div>
          <div class="card__date">${esc(a.published_at || '')}</div>
        </div>
      </a>`;
    }

    function renderSection(cat, killer, rest) {
      const total = (killer ? 1 : 0) + rest.length;
      const more = total > 5 ? `<a class="section-more" href="/category/${cat.slug}/">もっと見る →</a>` : '';
      const killerHtml = killer ? renderCard(killer, true, cat.label) : '';
      const cardsHtml = rest.slice(0, 6).map(a => renderCard(a, false, '')).join('');
      const empty = !killer && rest.length === 0
        ? '<div class="empty">このカテゴリの記事はまだありません。</div>'
        : '';
      return `<section class="section">
        <div class="section-header">
          <h2 class="section-title">${esc(cat.label)} <small>${total ? total + '記事' : ''}</small></h2>
          <div class="section-line"></div>
          ${more}
        </div>
        <div class="cards">
          ${killerHtml}
          ${cardsHtml}
        </div>
        ${empty}
      </section>`;
    }

    function renderSidebar(categories, counts, popular) {
      const catList = categories
        .filter(c => (counts[c.slug] || 0) > 0)
        .map(c => `<li><a href="/category/${c.slug}/">${esc(c.label)} <span class="count">${counts[c.slug]}</span></a></li>`)
        .join('');
      const popHtml = popular.map((a, i) => `
        <a href="${esc(a.url)}" class="popular-item">
          <div class="popular-item__rank">${i + 1}</div>
          <div class="popular-item__title">${esc(a.title)}</div>
        </a>
      `).join('');
      return `
        <div class="widget">
          <h3 class="widget__title">カテゴリ</h3>
          <ul class="widget__list">${catList || '<li style="color:#7b80a0;font-size:12px;padding:4px 10px;">まだ記事がありません</li>'}</ul>
        </div>
        <div class="widget">
          <h3 class="widget__title">人気記事</h3>
          <div class="popular-list">${popHtml || '<div style="color:#7b80a0;font-size:12px;">集計中</div>'}</div>
        </div>
      `;
    }

    async function load() {
      const mainCol = document.getElementById('main-col');
      const sidebar = document.getElementById('sidebar');
      try {
        const res = await fetch('/articles/index.json');
        if (!res.ok) throw new Error('index.json missing');
        const data = await res.json();

        const articles = data.articles || [];
        const categories = data.categories || [];
        const killerByCat = data.killer_by_category || {};
        const popular = data.popular_top5 || [];

        if (articles.length === 0) {
          mainCol.innerHTML = '<div class="empty">記事はまだありません</div>';
          sidebar.innerHTML = '';
          return;
        }

        const counts = {};
        for (const a of articles) {
          const c = a.category || 'general';
          counts[c] = (counts[c] || 0) + 1;
        }

        const sections = categories.map(cat => {
          const killer = killerByCat[cat.slug];
          const killerId = killer ? killer.task_id : null;
          const inCat = articles.filter(a => a.category === cat.slug && a.task_id !== killerId);
          return (killer || inCat.length) ? renderSection(cat, killer, inCat) : '';
        }).filter(Boolean).join('');

        mainCol.innerHTML = sections || '<div class="empty">記事がまだありません</div>';
        sidebar.innerHTML = renderSidebar(categories, counts, popular);
      } catch (e) {
        console.error(e);
        mainCol.innerHTML = '<div class="empty">記事の読み込みに失敗しました</div>';
        sidebar.innerHTML = '';
      }
    }
    load();
  </script>

</body>
</html>
