---
// src/pages/index.astro
// トップページ — 固定デザイン（変更しない）
// 記事リストは /articles/index.json から動的に読み込む
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Shift Breeze | AI・副業・キャリアの実践メディア</title>
  <meta name="description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。検索上位の情報より、一歩先の実践知識を。" />
  <meta property="og:title" content="Shift Breeze | AI・副業・キャリアの実践メディア" />
  <meta property="og:description" content="AI活用・副業・キャリアチェンジに関する実践的な情報をお届けします。" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;500;700&family=Outfit:wght@600;700;800&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

    :root {
      --bg: #0a0c12;
      --bg-card: #13161f;
      --bg-card-hover: #1a1d2a;
      --border: #1e2133;
      --accent: #6c63ff;
      --accent-2: #ff6584;
      --accent-glow: rgba(108, 99, 255, 0.12);
      --text: #dde1f0;
      --text-muted: #7b80a0;
      --heading: #ffffff;
      --font-body: 'Noto Sans JP', sans-serif;
      --font-display: 'Outfit', sans-serif;
    }

    html { scroll-behavior: smooth; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: var(--font-body);
      font-size: 16px;
      line-height: 1.8;
      -webkit-font-smoothing: antialiased;
      min-height: 100vh;
    }

    /* ヘッダー */
    .header {
      position: sticky;
      top: 0;
      z-index: 100;
      background: rgba(10, 12, 18, 0.88);
      backdrop-filter: blur(16px);
      border-bottom: 1px solid var(--border);
    }
    .header__inner {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px;
      height: 64px;
      display: flex;
      align-items: center;
      justify-content: space-between;
    }
    .logo {
      font-family: var(--font-display);
      font-size: 22px;
      font-weight: 800;
      color: var(--heading);
      text-decoration: none;
      letter-spacing: -0.03em;
    }
    .logo span { color: var(--accent); }

    /* ヒーロー */
    .hero {
      padding: 96px 24px 80px;
      text-align: center;
      position: relative;
      overflow: hidden;
    }
    .hero::before {
      content: '';
      position: absolute;
      top: -200px;
      left: 50%;
      transform: translateX(-50%);
      width: 800px;
      height: 800px;
      background: radial-gradient(circle, rgba(108,99,255,0.08) 0%, transparent 70%);
      pointer-events: none;
    }
    .hero__tag {
      display: inline-block;
      padding: 6px 16px;
      background: var(--accent-glow);
      border: 1px solid rgba(108,99,255,0.4);
      border-radius: 100px;
      font-size: 13px;
      color: #9d97ff;
      font-weight: 500;
      margin-bottom: 24px;
      letter-spacing: 0.05em;
    }
    .hero__title {
      font-family: var(--font-display);
      font-size: clamp(36px, 7vw, 64px);
      font-weight: 800;
      color: var(--heading);
      line-height: 1.15;
      letter-spacing: -0.03em;
      margin-bottom: 20px;
    }
    .hero__title em {
      font-style: normal;
      background: linear-gradient(135deg, var(--accent), var(--accent-2));
      -webkit-background-clip: text;
      -webkit-text-fill-color: transparent;
      background-clip: text;
    }
    .hero__desc {
      font-size: 18px;
      color: var(--text-muted);
      max-width: 520px;
      margin: 0 auto;
      line-height: 1.7;
    }

    /* 記事グリッド */
    .articles-section {
      max-width: 1200px;
      margin: 0 auto;
      padding: 0 24px 96px;
    }
    .section-header {
      display: flex;
      align-items: center;
      gap: 12px;
      margin-bottom: 32px;
    }
    .section-title {
      font-family: var(--font-display);
      font-size: 20px;
      font-weight: 700;
      color: var(--heading);
    }
    .section-line {
      flex: 1;
      height: 1px;
      background: var(--border);
    }
    .articles-grid {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
      gap: 24px;
    }

    /* 記事カード */
    .article-card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 16px;
      overflow: hidden;
      text-decoration: none;
      display: flex;
      flex-direction: column;
      transition: transform 0.2s ease, border-color 0.2s ease, box-shadow 0.2s ease;
    }
    .article-card:hover {
      transform: translateY(-6px);
      border-color: var(--accent);
      box-shadow: 0 16px 40px rgba(108,99,255,0.12);
    }
    .article-card__img {
      width: 100%;
      aspect-ratio: 16/9;
      object-fit: cover;
      background: linear-gradient(135deg, #13161f 0%, #1e2133 100%);
      display: block;
    }
    .article-card__img-placeholder {
      width: 100%;
      aspect-ratio: 16/9;
      background: linear-gradient(135deg, #13161f 0%, #1e2133 100%);
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--text-muted);
      font-size: 32px;
    }
    .article-card__body {
      padding: 20px 24px 24px;
      flex: 1;
      display: flex;
      flex-direction: column;
    }
    .article-card__kw {
      display: inline-block;
      padding: 4px 12px;
      background: var(--accent-glow);
      border: 1px solid rgba(108,99,255,0.35);
      border-radius: 100px;
      font-size: 12px;
      color: #9d97ff;
      font-weight: 500;
      margin-bottom: 12px;
      width: fit-content;
    }
    .article-card__title {
      font-family: var(--font-display);
      font-size: 17px;
      font-weight: 700;
      color: var(--heading);
      line-height: 1.45;
      margin-bottom: 10px;
    }
    .article-card__desc {
      font-size: 14px;
      color: var(--text-muted);
      line-height: 1.65;
      flex: 1;
      display: -webkit-box;
      -webkit-line-clamp: 3;
      -webkit-box-orient: vertical;
      overflow: hidden;
    }
    .article-card__footer {
      display: flex;
      align-items: center;
      justify-content: space-between;
      margin-top: 16px;
      padding-top: 14px;
      border-top: 1px solid var(--border);
    }
    .article-card__date {
      font-size: 12px;
      color: var(--text-muted);
    }
    .article-card__arrow {
      width: 28px;
      height: 28px;
      background: var(--accent-glow);
      border: 1px solid rgba(108,99,255,0.3);
      border-radius: 50%;
      display: flex;
      align-items: center;
      justify-content: center;
      color: var(--accent);
      font-size: 14px;
      transition: background 0.15s;
    }
    .article-card:hover .article-card__arrow {
      background: var(--accent);
      color: white;
    }

    /* ローディング・空状態 */
    .loading {
      text-align: center;
      padding: 64px 0;
      color: var(--text-muted);
    }
    .empty {
      text-align: center;
      padding: 64px 0;
      color: var(--text-muted);
      grid-column: 1 / -1;
    }

    /* フッター */
    .footer {
      border-top: 1px solid var(--border);
      padding: 32px 24px;
      text-align: center;
      color: var(--text-muted);
      font-size: 14px;
    }
    .footer a {
      color: var(--text-muted);
      text-decoration: none;
    }
    .footer a:hover { color: var(--accent); }

    /* レスポンシブ */
    @media (max-width: 640px) {
      .hero { padding: 64px 16px 48px; }
      .articles-section { padding: 0 16px 64px; }
      .articles-grid { grid-template-columns: 1fr; }
    }
  </style>
</head>
<body>

  <header class="header">
    <div class="header__inner">
      <a href="/" class="logo">Shift<span>Breeze</span></a>
    </div>
  </header>

  <main>
    <div class="hero">
      <div class="hero__tag">AI × 副業 × キャリア</div>
      <h1 class="hero__title">
        検索上位より<br>
        <em>一歩先の実践知識</em>を
      </h1>
      <p class="hero__desc">
        AI活用・副業・キャリアチェンジに関する、実際に使える情報をお届けします
      </p>
    </div>

    <section class="articles-section">
      <div class="section-header">
        <h2 class="section-title">最新記事</h2>
        <div class="section-line"></div>
      </div>
      <div class="articles-grid" id="articles-grid">
        <div class="loading">記事を読み込んでいます...</div>
      </div>
    </section>
  </main>

  <footer class="footer">
    <p>© 2026 <a href="/">ShiftBreeze</a>. All rights reserved.</p>
  </footer>

  <script>
    async function loadArticles() {
      const grid = document.getElementById('articles-grid');
      try {
        const res = await fetch('/articles/index.json');
        if (!res.ok) throw new Error('index.json not found');
        const data = await res.json();
        const articles = data.articles || [];

        if (articles.length === 0) {
          grid.innerHTML = '<div class="empty">記事はまだありません</div>';
          return;
        }

        grid.innerHTML = articles.map(article => `
          <a href="${article.url}" class="article-card">
            ${article.eyecatch
              ? `<img class="article-card__img" src="${article.eyecatch}" alt="${article.title}" loading="lazy" onerror="this.style.display='none'">`
              : `<div class="article-card__img-placeholder">📝</div>`
            }
            <div class="article-card__body">
              <span class="article-card__kw">${article.keyword || 'AI・副業'}</span>
              <div class="article-card__title">${article.title}</div>
              <div class="article-card__desc">${article.description || ''}</div>
              <div class="article-card__footer">
                <span class="article-card__date">${article.published_at}</span>
                <span class="article-card__arrow">→</span>
              </div>
            </div>
          </a>
        `).join('');
      } catch (e) {
        grid.innerHTML = '<div class="empty">記事の読み込みに失敗しました</div>';
        console.error('Failed to load articles:', e);
      }
    }

    loadArticles();
  </script>

</body>
</html>
